options:
  parameters:
    author: Jakob Kunzler
    catch_exceptions: 'True'
    category: '[GRC Hier Blocks]'
    cmake_opt: ''
    comment: ''
    copyright: ''
    description: ''
    gen_cmake: 'On'
    gen_linking: dynamic
    generate_options: qt_gui
    hier_block_src_path: '.:'
    id: harness_pluto_tx
    max_nouts: '0'
    output_language: python
    placement: (0,0)
    qt_qss_theme: ''
    realtime_scheduling: ''
    run: 'True'
    run_command: '{python} -u {filename}'
    run_options: prompt
    sizing_mode: fixed
    thread_safe_setters: ''
    title: Harness of ADALM Pluto TX
    window_size: (1000,1000)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 8]
    rotation: 0
    state: enabled

blocks:
- name: center_frequency
  id: qtgui_msgdigitalnumbercontrol
  parameters:
    ThousandsSeparator: ','
    affinity: ''
    alias: ''
    comment: ''
    gui_hint: 1,4,1,1
    lbl: Carrier Frequency
    maxFreqHz: 928E6
    maxoutbuf: '0'
    minFreqHz: 902E6
    minoutbuf: '0'
    outputmsgname: freq
    readOnly: 'False'
    relBackgroundColor: black
    relFontColor: white
    value: 915E6
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [344, 8.0]
    rotation: 0
    state: enabled
- name: enable_gui
  id: variable_qtgui_toggle_switch
  parameters:
    cellalignment: '1'
    comment: ''
    gui_hint: 0,4,1,1
    initPressed: 'True'
    label: Enable  GUI
    outputmsgname: value
    position: '4'
    pressed: '1'
    released: '0'
    switchOffBackground: gray
    switchOnBackground: green
    type: int
    value: '1'
    verticalalignment: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [864, 160.0]
    rotation: 0
    state: enabled
- name: enable_tx
  id: variable_qtgui_toggle_switch
  parameters:
    cellalignment: '1'
    comment: ''
    gui_hint: 0,3,1,1
    initPressed: 'True'
    label: RF ON
    outputmsgname: value
    position: '4'
    pressed: '1'
    released: '0'
    switchOffBackground: gray
    switchOnBackground: green
    type: bool
    value: '1'
    verticalalignment: '1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [648, 24.0]
    rotation: 0
    state: enabled
- name: gain_db
  id: variable_qtgui_range
  parameters:
    comment: ''
    gui_hint: 2,3,1,1
    label: DSP Gain (dB)
    min_len: '200'
    orient: QtCore.Qt.Horizontal
    rangeType: float
    start: '-60'
    step: '3'
    stop: '60'
    value: '0'
    widget: counter_slider
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1472, 32.0]
    rotation: 0
    state: enabled
- name: pluto_uri
  id: variable
  parameters:
    comment: ''
    value: iio.get_pluto_uri()
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1200, 120]
    rotation: 0
    state: enabled
- name: radio_attenuation_db
  id: variable_qtgui_range
  parameters:
    comment: ''
    gui_hint: 1,3,1,1
    label: Radio Gain (dB)
    min_len: '200'
    orient: QtCore.Qt.Horizontal
    rangeType: float
    start: '0'
    step: '3'
    stop: '40'
    value: '10'
    widget: counter_slider
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [896, 16.0]
    rotation: 0
    state: enabled
- name: radio_source
  id: variable_qtgui_chooser
  parameters:
    comment: ''
    gui_hint: 2,4,1,1
    label: Radio Source
    label0: Zero
    label1: Wavegenerator
    label2: f"ZMQ Port:{zmq_base_port+zmq_pull_offset}"
    label3: ''
    label4: ''
    labels: '[]'
    num_opts: '3'
    option0: '0'
    option1: '1'
    option2: '2'
    option3: '3'
    option4: '4'
    options: '[0, 1, 2]'
    orient: Qt.QVBoxLayout
    type: int
    value: '2'
    widget: combo_box
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [648, 176.0]
    rotation: 0
    state: enabled
- name: samp_rate
  id: variable
  parameters:
    comment: ''
    value: int(1E6)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [200, 12]
    rotation: 0
    state: enabled
- name: waveform
  id: variable_qtgui_chooser
  parameters:
    comment: ''
    gui_hint: 3,3,1,1
    label: Waveform Type
    label0: Cosine
    label1: Square
    label2: Triangle
    label3: Saw Tooth
    label4: Constant
    labels: '["Constant","Cosine","Square","Triangle","Saw Tooth","Noise"]'
    num_opts: '0'
    option0: '1'
    option1: '2'
    option2: '3'
    option3: '4'
    option4: '0'
    options: '[0,1,2,3,4,5]'
    orient: Qt.QVBoxLayout
    type: int
    value: '1'
    widget: combo_box
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [312, 212.0]
    rotation: 0
    state: enabled
- name: waveform_frequency
  id: variable_qtgui_range
  parameters:
    comment: ''
    gui_hint: 3,4,1,1
    label: Waveform Frequency
    min_len: '200'
    orient: QtCore.Qt.Horizontal
    rangeType: float
    start: -samp_rate*0.5
    step: '1'
    stop: samp_rate*0.5
    value: '1000'
    widget: eng_slider
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [248, 528.0]
    rotation: 0
    state: enabled
- name: waveform_offset
  id: variable_qtgui_range
