    gui_hint: 4,3,1,1
    label: Waveform Offset
    min_len: '200'
    orient: QtCore.Qt.Horizontal
    rangeType: float
    start: '-1.0'
    step: 1E-6
    stop: '1.0'
    value: '0.0'
    widget: eng_slider
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [248, 664.0]
    rotation: 0
    state: enabled
- name: waveform_phase
  id: variable_qtgui_range
  parameters:
    comment: ''
    gui_hint: 4,4,1,1
    label: Waveform Phase (normalized)
    min_len: '200'
    orient: QtCore.Qt.Horizontal
    rangeType: float
    start: '-1.0'
    step: 1E-6
    stop: '1.0'
    value: '0.0'
    widget: eng_slider
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [232, 808.0]
    rotation: 0
    state: enabled
